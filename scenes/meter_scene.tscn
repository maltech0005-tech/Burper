[gd_scene load_steps=77 format=4 uid="uid://c7765orpdoc1p"]

[ext_resource type="Texture2D" uid="uid://cdcigcne2u1x7" path="res://assets/BurpMeter.png" id="1_au8l4"]
[ext_resource type="Texture2D" uid="uid://ccliveox0nqo4" path="res://assets/BurperSpriteSheet.png" id="2_qgidq"]

[sub_resource type="GDScript" id="GDScript_qgidq"]
script/source = "extends Node2D
@onready var player: CharacterBody2D = $player
@onready var meter: AnimatedSprite2D = $meter
@onready var platform: TileMapLayer = $platform

var player1 = null
var cap : int
var meter_level=0
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	player1 = get_tree().get_first_node_in_group(\"player\")
	
# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	if player1:
		cap=player1.cola_cap
		

func _on_area_2d_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"1v1\"):
		platform.visible = false
		get_meter_value()
		
func get_meter_value():
	if cap<12.5:
		meter_level=1
	elif cap>12.5 and cap<25:
		meter_level=2
	elif cap<25 and cap<37.5:
		meter_level=3
	elif cap<37.5 and cap<50:
		meter_level=4
	elif cap>50 and cap<62.5:
		meter_level=5
	elif cap<62.5 and cap<75:
		meter_level=6
	elif cap<12.5 and cap<12.5:
		meter_level=7
	elif cap>75 and cap<87.5:
		meter_level=8
	elif cap<87.5 and cap<100:
		meter_level=9
	else:
		meter_level=10

func start_meter_animation():
	if meter_level==1:
		meter.play(\"1\")
	if meter_level==2:
		meter.play(\"2\")
	if meter_level==3:
		meter.play(\"3\")
	if meter_level==4:
		meter.play(\"4\")
	if meter_level==5:
		meter.play(\"5\")
	if meter_level==6:
		meter.play(\"6\")
	if meter_level==7:
		meter.play(\"7\")
	if meter_level==8:
		meter.play(\"8\")
	if meter_level==9:
		meter.play(\"breaker\")
"

