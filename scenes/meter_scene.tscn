[sub_resource type="RectangleShape2D" id="RectangleShape2D_ad0iy"]
size = Vector2(765, 9.25)

[sub_resource type="GDScript" id="GDScript_au8l4"]
script/source = "extends CharacterBody2D

func _ready() -> void:
	add_to_group(\"1v1\")

func _physics_process(delta: float) -> void:
	# Add the gravity.
	if not is_on_floor():
		velocity += get_gravity() * delta * 0.5

	move_and_slide()
"

