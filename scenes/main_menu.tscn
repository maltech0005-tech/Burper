[sub_resource type="GDScript" id="GDScript_rtw2f"]
resource_name = "main_m_enemy"
script/source = "extends CharacterBody2D
@onready var sprite: AnimatedSprite2D = $sprite

var burped = false
const JUMP_VELOCITY = -400.0

func _ready() -> void:
	add_to_group(\"main_m_enemy\")
	visible	= true
	sprite.play()

func _physics_process(delta: float) -> void:
	play_loop()
	move_and_slide()
	
func _on_area_2d_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"main_m_player\"):
		sprite.stop()
		burped=true
		
func play_loop():
	if position.x<180:
		velocity=Vector2(65, -68)
	else:
		velocity=Vector2(40, 0)
	if burped:
		velocity=Vector2(-225, 24)
		if position.x<-100:
			visible=false
			velocity = Vector2.ZERO
			position= Vector2(58, 174)
			random_sprite()
			visible=true
			burped=false
	
	
		
func random_sprite():
	var n = randi_range(1,6)
	sprite.play(\"e\"+str(n))
"

