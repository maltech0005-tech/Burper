[sub_resource type="TileSet" id="TileSet_tbmy8"]
sources/1 = SubResource("TileSetAtlasSource_ekxnf")

[sub_resource type="GDScript" id="GDScript_ekxnf"]
resource_name = "main_m_player"
script/source = "extends CharacterBody2D
@onready var sprite: AnimatedSprite2D = $sprite
@onready var spritebase: AnimatedSprite2D = $spritebase
@onready var burp: AnimatedSprite2D = $burp
@onready var sprite_crown: AnimatedSprite2D = $sprite_crown
@onready var btime: Timer = $btime

var current_burp_level=-1

func _ready() -> void:
	add_to_group(\"main_m_player\")
	sprite.flip_h=true
	spritebase.flip_h=true
	burp.flip_h=true
	sprite_crown.flip_h=true

func _physics_process(_delta: float) -> void:

	move_and_slide()


func _on_area_2d_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"main_m_enemy\"):
		burp.visible=true
		burp.play(\"1\")
		start_burp()
		
func _on_area_2d_body_exited(body: Node2D) -> void:
	if body.is_in_group(\"main_m_enemy\"):
		burp.visible=false
		
func start_burp():
	burp.global_position.x=342-8*current_burp_level
	burp.play(str(current_burp_level+1))
	btime.start(0.2)
	
	
func _on_btime_timeout() -> void:
	if current_burp_level<3:
		current_burp_level+=1
	else:
		current_burp_level=0
	start_burp()	
	
"

